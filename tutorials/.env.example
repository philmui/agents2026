# Shared API keys for ALL tutorial modules.
# Copy this file to `.env` in THIS folder (tutorials/.env) and fill in real values.
# Every module's notebook calls load_dotenv(find_dotenv()), which walks UP the
# directory tree and finds THIS shared file automatically — no per-module copy.
#
# .env is gitignored. NEVER commit real keys. If a key leaks, rotate it immediately.

# Cloud Ollama — used from Module 05 onward (chat/generator, judge, embeddings).
# Get one at https://ollama.com (cloud). The local daemon relays ":cloud" models.
OLLAMA_API_KEY=

# Cohere reranking — used from Module 10 onward. https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Metals.dev live prices — used from Module 11 onward. https://metals.dev
METALS_API_KEY=
